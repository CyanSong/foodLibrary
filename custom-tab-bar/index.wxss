.tabbar-shell {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 99;
  padding-bottom: env(safe-area-inset-bottom);
  background: rgba(255, 248, 240, 0.98);
  border-top: 1rpx solid rgba(211, 195, 174, 0.92);
  box-shadow: 0 -10rpx 24rpx rgba(87, 58, 26, 0.08);
}

.tabbar {
  display: flex;
  align-items: stretch;
  justify-content: space-between;
  padding: 10rpx 18rpx 12rpx;
}

.tabbar__item {
  flex: 1 1 0;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 10rpx 12rpx 8rpx;
  border-radius: 22rpx;
  color: #7b685a;
  transition: background-color 160ms ease, color 160ms ease;
}

.tabbar__item.is-active {
  background: rgba(243, 210, 187, 0.68);
  color: #bb4f1d;
}

.tabbar__icon {
  position: relative;
  width: 46rpx;
  height: 40rpx;
  color: currentColor;
}

.tabbar__icon.is-active {
  color: #bb4f1d;
}

.tabbar__label {
  font-size: 20rpx;
  line-height: 1.3;
  font-weight: 600;
}

.tabbar__upload-tray {
  position: absolute;
  left: 8rpx;
  right: 8rpx;
  bottom: 4rpx;
  height: 8rpx;
  border-left: 4rpx solid currentColor;
  border-right: 4rpx solid currentColor;
  border-bottom: 4rpx solid currentColor;
  border-radius: 0 0 10rpx 10rpx;
}

.tabbar__upload-stem {
  position: absolute;
  left: 50%;
  top: 4rpx;
  width: 4rpx;
  height: 22rpx;
  margin-left: -2rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.tabbar__upload-head {
  position: absolute;
  top: 4rpx;
  width: 16rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.tabbar__upload-head--left {
  left: 50%;
  margin-left: -14rpx;
  transform: rotate(-45deg);
  transform-origin: right center;
}

.tabbar__upload-head--right {
  left: 50%;
  margin-left: -2rpx;
  transform: rotate(45deg);
  transform-origin: left center;
}

.tabbar__search-ring {
  position: absolute;
  left: 8rpx;
  top: 4rpx;
  width: 20rpx;
  height: 20rpx;
  border: 4rpx solid currentColor;
  border-radius: 999rpx;
}

.tabbar__search-handle {
  position: absolute;
  right: 8rpx;
  bottom: 8rpx;
  width: 18rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: currentColor;
  transform: rotate(45deg);
  transform-origin: center;
}
