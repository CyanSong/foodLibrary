page {
  min-height: 100%;
  min-height: 100vh;
  background:
    radial-gradient(circle at top left, rgba(255, 255, 255, 0.72), transparent 30%),
    linear-gradient(180deg, #f4efe6 0%, #e7dccd 100%);
  color: #2f261c;
  font-size: 26rpx;
}

view,
text,
button,
input,
textarea,
image {
  box-sizing: border-box;
}

button,
input,
textarea {
  font-size: 26rpx;
  color: inherit;
}

button {
  padding: 0;
  margin: 0;
  line-height: 1.2;
  background: transparent;
}

button::after {
  border: none;
}

.page-shell {
  padding: 20rpx 18rpx calc(26rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(26rpx + env(safe-area-inset-bottom));
}

.hero-card,
.panel-card,
.empty-card {
  background: rgba(255, 251, 245, 0.92);
  border: 1rpx solid rgba(211, 195, 174, 0.92);
  border-radius: 24rpx;
  box-shadow: 0 12rpx 28rpx rgba(87, 58, 26, 0.08);
}

.hero-card {
  margin-bottom: 18rpx;
  padding: 22rpx;
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.22;
}

.hero-copy,
.panel-copy,
.field-hint,
.meta-copy,
.empty-card,
.path-copy,
.toolbar-copy {
  color: #706352;
}

.hero-copy {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
}

.panel-card {
  margin-bottom: 18rpx;
  padding: 20rpx;
}

.panel-head,
.results-header {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.panel-head {
  margin-bottom: 16rpx;
}

.panel-title-group {
  min-width: 0;
}

.panel-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
}

.panel-copy {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.6;
}

.panel-badge,
.results-count {
  flex-shrink: 0;
  min-width: 74rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f3d2bb;
  color: #7c3813;
  text-align: center;
  font-size: 22rpx;
}

.form-stack {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.field-block {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.field-label,
.meta-label,
.path-builder-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
}

.field-input,
.field-textarea,
.picker-field {
  width: 100%;
  padding: 18rpx 20rpx;
  border: 1rpx solid rgba(211, 195, 174, 0.92);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.76);
}

.field-textarea {
  min-height: 148rpx;
  line-height: 1.6;
}

.field-hint,
.meta-copy,
.path-copy,
.toolbar-copy {
  display: block;
  font-size: 22rpx;
  line-height: 1.6;
}

.button-row {
  display: flex;
  flex-wrap: wrap;
  align-items: stretch;
  gap: 10rpx;
}

.button-row button {
  flex: 1 1 0;
  min-width: 0;
}

.primary-button,
.secondary-button,
.ghost-button,
.danger-button,
.icon-button,
.chip-tap {
  border-radius: 999rpx;
}

.primary-button,
.secondary-button,
.ghost-button,
.danger-button {
  padding: 18rpx 22rpx;
  text-align: center;
}

.primary-button {
  background: #9a4d22;
  color: #fff8f2;
}

.secondary-button {
  background: #f3d2bb;
  color: #7c3813;
}

.ghost-button {
  background: rgba(255, 255, 255, 0.82);
  color: #5f4a38;
  border: 1rpx solid rgba(209, 183, 153, 0.88);
}

.danger-button {
  background: rgba(156, 76, 59, 0.12);
  color: #8c3f31;
  border: 1rpx solid rgba(156, 76, 59, 0.28);
}

.ghost-button--small,
.secondary-button--small {
  padding: 12rpx 16rpx;
  font-size: 22rpx;
}

.image-preview {
  min-height: 180rpx;
  border: 1rpx dashed rgba(209, 183, 153, 0.92);
  border-radius: 20rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.52);
}

.image-preview--empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 22rpx;
  text-align: center;
  color: #706352;
}

.tag-builder {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 18rpx;
  border: 1rpx solid rgba(211, 195, 174, 0.92);
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.42);
}

.path-builder {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 16rpx;
  border: 1rpx solid rgba(209, 183, 153, 0.9);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.68);
}

.path-builder-head {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.path-builder-topline {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-start;
  justify-content: space-between;
  gap: 10rpx;
}

.path-builder-entry {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.path-builder-entry-controls {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.picker-field {
  min-height: 76rpx;
  display: flex;
  align-items: center;
  color: #5f4a38;
}

.picker-field--disabled {
  color: #8e7f71;
  background: rgba(255, 255, 255, 0.5);
}

.path-preview {
  min-height: 60rpx;
  padding: 14rpx 16rpx;
  border: 1rpx dashed rgba(209, 183, 153, 0.92);
  border-radius: 18rpx;
  background: rgba(255, 252, 246, 0.92);
}

.path-preview__chips,
.chip-wrap,
.selected-filter-list {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-start;
  align-content: flex-start;
  justify-content: flex-start;
  gap: 8rpx;
}

.path-preview__item {
  display: inline-flex;
  align-items: center;
  flex: 0 0 auto;
  min-width: 0;
  max-width: 100%;
  gap: 6rpx;
}

.chip-wrap--compact {
  gap: 6rpx;
}

.path-chip,
.chip,
.selected-tag {
  display: inline-flex;
  align-items: center;
  flex-wrap: wrap;
  max-width: 100%;
  gap: 6rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
}

.path-chip,
.chip {
  border: 1rpx solid rgba(209, 183, 153, 0.88);
  background: #f2e6d8;
  color: #5f4a38;
}

.path-chip {
  flex: 0 0 auto;
  min-width: 0;
  max-width: 100%;
  height: 40rpx;
  flex-wrap: nowrap;
  align-items: center;
  overflow: hidden;
  padding-top: 0;
  padding-bottom: 0;
  color: #7c3813;
}

.path-chip__label {
  display: block;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.path-chip__arrow {
  display: inline-flex;
  align-items: center;
  flex-shrink: 0;
  color: #706352;
}

.chip-tap {
  display: inline-flex;
  flex: 0 0 auto;
  width: auto;
  min-width: 0;
  max-width: 100%;
  padding: 0;
  border: none;
  background: transparent;
}

.chip-tap--compact .chip,
.chip--compact {
  gap: 4rpx;
  padding: 6rpx 12rpx;
}

.recent-tag-list {
  flex-direction: column;
  align-items: stretch;
  gap: 8rpx;
}

.recent-tag-item {
  display: flex;
  width: 100%;
  max-width: none;
}

.recent-tag-chip {
  width: 100%;
  min-width: 0;
  flex-wrap: nowrap;
  gap: 10rpx;
  padding: 10rpx 14rpx;
  border-radius: 18rpx;
}

.recent-tag-chip .chip__meta {
  flex: 0 0 auto;
}

.recent-tag-chip .chip__label {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.chip--compact text {
  font-size: 22rpx;
  line-height: 1.3;
}

.chip.is-active {
  background: #f3d2bb;
  color: #7c3813;
  border-color: #9a4d22;
}

.chip__meta {
  opacity: 0.74;
  font-size: 20rpx;
}

.chip__label {
  font-size: 22rpx;
  line-height: 1.45;
}

.field-input {
  min-height: 76rpx;
}

.field-input--compact {
  padding-top: 16rpx;
  padding-bottom: 16rpx;
  font-size: 22rpx;
}

.path-builder-input {
  width: 100%;
}

.path-entry-hint {
  margin-top: 2rpx;
}

.meta-stack {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.selected-tag {
  background: #f3d2bb;
  color: #7c3813;
}

.selected-tag__remove {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  position: relative;
  flex: 0 0 auto;
  width: 32rpx;
  height: 32rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #7c3813;
}

.selected-tag__remove-line {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 14rpx;
  height: 2rpx;
  border-radius: 999rpx;
  background: #7c3813;
  transform-origin: center;
}

.selected-tag__remove-line--start {
  transform: translate(-50%, -50%) rotate(45deg);
}

.selected-tag__remove-line--end {
  transform: translate(-50%, -50%) rotate(-45deg);
}

.toolbar-card {
  margin-bottom: 14rpx;
  padding: 16rpx;
  border: 1rpx solid rgba(211, 195, 174, 0.92);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.42);
}

.toolbar-label {
  display: block;
  color: #706352;
  font-size: 20rpx;
  letter-spacing: 0.12em;
  text-transform: uppercase;
}

.toolbar-copy {
  margin-top: 10rpx;
}

.toolbar-actions {
  margin-top: 12rpx;
}

.browser-stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.browser-column {
  min-width: 0;
}

.tree-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.tree-node {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tree-row {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
}

.tree-item-button {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  padding: 14rpx 12rpx;
  border: 1rpx solid rgba(209, 183, 153, 0.88);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.78);
  text-align: left;
}

.tree-item-button--static {
  background: rgba(255, 255, 255, 0.78);
}

.tree-toggle__icon {
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
  border: 1rpx solid rgba(209, 183, 153, 0.92);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.86);
  color: #7c3813;
  text-align: center;
  line-height: 34rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.tree-toggle__icon--dot {
  font-size: 26rpx;
  line-height: 32rpx;
}

.tree-item-button__text {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.tree-item-button__label {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.35;
}

.tree-toggle__path {
  display: block;
  color: #706352;
  font-size: 20rpx;
  line-height: 1.5;
}

.tag-button__count {
  flex-shrink: 0;
  min-width: 34rpx;
  padding: 4rpx 8rpx;
  border-radius: 999rpx;
  background: #f2e6d8;
  text-align: center;
  font-size: 20rpx;
}

.tree-row__actions {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 4rpx;
}

.index-action-button {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  flex: 0 0 42rpx;
  width: 42rpx;
  min-width: 42rpx;
  height: 42rpx;
  padding: 0;
  border: 1rpx solid rgba(209, 183, 153, 0.92);
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.84);
  text-align: center;
  color: #7c3813;
  font-size: 20rpx;
  line-height: 1;
}

.index-action-button--select {
  color: rgba(124, 56, 19, 0.42);
}

.index-action-button--select.is-selected,
.index-action-button--favorite.is-selected {
  border-color: #9a4d22;
  background: #f3d2bb;
  color: #7c3813;
}

.index-action-button--favorite {
  font-size: 24rpx;
}

.index-action-button--delete {
  color: #9c4c3b;
}

.index-action-button__cross-line {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 16rpx;
  height: 2rpx;
  border-radius: 999rpx;
  background: currentColor;
  transform-origin: center;
}

.index-action-button__cross-line--start {
  transform: translate(-50%, -50%) rotate(45deg);
}

.index-action-button__cross-line--end {
  transform: translate(-50%, -50%) rotate(-45deg);
}

.results-header {
  margin-bottom: 12rpx;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.empty-card {
  padding: 22rpx 18rpx;
  text-align: center;
  line-height: 1.7;
}

@media (max-width: 375px) {
  .page-shell {
    padding: 16rpx 14rpx calc(22rpx + constant(safe-area-inset-bottom));
    padding-bottom: calc(22rpx + env(safe-area-inset-bottom));
  }

  .hero-card,
  .panel-card {
    padding: 18rpx;
  }

  .hero-title {
    font-size: 34rpx;
  }

  .panel-title,
  .builder-section-title,
  .browser-section-title {
    font-size: 28rpx;
  }

  .field-input,
  .field-textarea,
  .picker-field {
    padding: 16rpx 18rpx;
  }

  .primary-button,
  .secondary-button,
  .ghost-button,
  .danger-button {
    padding: 16rpx 18rpx;
  }

  .tree-row {
    flex-direction: column;
  }

  .tree-row__actions {
    width: 100%;
    justify-content: flex-end;
  }
}
